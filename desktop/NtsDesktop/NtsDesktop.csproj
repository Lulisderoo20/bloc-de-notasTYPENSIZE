<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net7.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>..\..\assets\nts-icon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3856.49" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="..\..\index.html" Link="web\index.html" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\styles.css" Link="web\styles.css" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\script.js" Link="web\script.js" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\assets\**\*" Link="web\assets\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
